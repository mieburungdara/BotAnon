# Database mode: "sqlite" or "postgresql"
DB_MODE=sqlite

# Bot token from @BotFather
BOT_TOKEN=your_bot_token_here

# PostgreSQL connection (only needed when DB_MODE=postgresql)
DATABASE_URL=postgresql://username:password@localhost:5432/botanondb

# Webhook Configuration (Optional for production)
USE_WEBHOOK=false
WEBHOOK_DOMAIN=https://your-domain.com
WEBHOOK_PORT=3000
WEBHOOK_PATH=/telegraf/secret-path

# Logging
LOG_LEVEL=info
NODE_ENV=development