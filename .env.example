# Database Mode (MySQL is recommended for shared hosting)
DB_MODE=mysql

# Bot token from @BotFather
BOT_TOKEN=your_bot_token_here

# MySQL connection string (Example for JagoanHosting/cPanel)
DATABASE_URL=mysql://user:pass@lucky.jagoanhosting.id:3306/db_name

# Webhook Configuration (Required for Shared Hosting)
USE_WEBHOOK=false
WEBHOOK_DOMAIN=yourdomain.com
WEBHOOK_PORT=3000
WEBHOOK_PATH=/botanon/telegraf/secret-xyz-123
PORT=3000


# Logging
LOG_LEVEL=info
NODE_ENV=development